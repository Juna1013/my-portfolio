---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import SiteHeader from '../components/SiteHeader.astro';
import { about } from '../data/about';
import { blog } from '../data/blog';
import { works } from '../data/works';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatBlogDate = (date: Date) =>
  `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}`;

const title = '准 — JUNA | Portfolio';
const description = '川崎准也（ジュナ）のポートフォリオ。LLMエージェントセキュリティの研究、公開アプリケーション、技術ブログの記録。';
---
<!DOCTYPE html>
<html lang="ja" id="top">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="description" content={description}>
<meta name="author" content="川崎准也">
<meta name="generator" content={Astro.generator}>
<meta name="robots" content="index, follow">
<meta name="theme-color" content="#f0e8d5">
<meta property="og:type" content="website">
<meta property="og:locale" content="ja_JP">
<meta property="og:site_name" content="准 — JUNA">
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content={title}>
<meta name="twitter:description" content={description}>
<title>{title}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;500;600;700&family=Cormorant+Garamond:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body>

<!-- 共有defs（桜の花・フィルタ） -->
<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <filter id="inkRough" x="-15%" y="-15%" width="130%" height="130%">
      <feTurbulence type="fractalNoise" baseFrequency="0.032" numOctaves="4" seed="8" result="n"/>
      <feDisplacementMap in="SourceGraphic" in2="n" scale="7"/>
    </filter>
    <filter id="inkRoughFine" x="-15%" y="-15%" width="130%" height="130%">
      <feTurbulence type="fractalNoise" baseFrequency="0.09" numOctaves="3" seed="4" result="n2"/>
      <feDisplacementMap in="SourceGraphic" in2="n2" scale="3.5"/>
    </filter>
    <filter id="hakeRough" x="-20%" y="-40%" width="140%" height="180%">
      <feTurbulence type="fractalNoise" baseFrequency="0.018 0.09" numOctaves="4" seed="13" result="h"/>
      <feDisplacementMap in="SourceGraphic" in2="h" scale="22"/>
    </filter>

    <path id="spetal" d="M0 -5.2 C-0.6 -6.4 -2.4 -7 -3.6 -6 C-5.4 -4.4 -5.6 -0.8 -4.2 2 C-2.9 4.6 -1.4 5.6 0 6.6 C1.4 5.6 2.9 4.6 4.2 2 C5.6 -0.8 5.4 -4.4 3.6 -6 C2.4 -7 0.6 -6.4 0 -5.2 Z"/>
    <g id="sb0">
      <g fill="#e4afba" stroke="#b97f8e" stroke-width=".5">
        <use href="#spetal" transform="rotate(0) translate(0 -7.4)" opacity=".95"/>
        <use href="#spetal" transform="rotate(72) translate(0 -7.4)" opacity=".85"/>
        <use href="#spetal" transform="rotate(144) translate(0 -7.4)" opacity=".9"/>
        <use href="#spetal" transform="rotate(216) translate(0 -7.4)" opacity=".82"/>
        <use href="#spetal" transform="rotate(288) translate(0 -7.4)" opacity=".88"/>
      </g>
      <circle r="1.7" fill="#a75f6f"/>
      <g fill="#e9d08a" opacity=".95">
        <circle cx="0" cy="-3" r=".6"/><circle cx="2.85" cy="-.95" r=".6"/>
        <circle cx="1.75" cy="2.45" r=".6"/><circle cx="-1.75" cy="2.45" r=".6"/>
        <circle cx="-2.85" cy="-.95" r=".6"/>
      </g>
    </g>
    <g id="sb1">
      <g fill="#cf8ea0" stroke="#a4677a" stroke-width=".5">
        <use href="#spetal" transform="rotate(0) translate(0 -7.4)" opacity=".93"/>
        <use href="#spetal" transform="rotate(72) translate(0 -7.4)" opacity=".84"/>
        <use href="#spetal" transform="rotate(144) translate(0 -7.4)" opacity=".9"/>
        <use href="#spetal" transform="rotate(216) translate(0 -7.4)" opacity=".8"/>
        <use href="#spetal" transform="rotate(288) translate(0 -7.4)" opacity=".87"/>
      </g>
      <circle r="1.7" fill="#8f4c5d"/>
    </g>
    <g id="sb2">
      <g fill="#f0e8d5" stroke="#4a4038" stroke-width=".8">
        <use href="#spetal" transform="rotate(0) translate(0 -7.4)"/>
        <use href="#spetal" transform="rotate(72) translate(0 -7.4)"/>
        <use href="#spetal" transform="rotate(144) translate(0 -7.4)"/>
        <use href="#spetal" transform="rotate(216) translate(0 -7.4)"/>
        <use href="#spetal" transform="rotate(288) translate(0 -7.4)"/>
      </g>
      <circle r="1.3" fill="#4a4038"/>
    </g>
    <g id="sbud">
      <circle r="2.8" fill="#d59aa9"/>
      <circle r="2.8" fill="none" stroke="#a4677a" stroke-width=".5"/>
      <path d="M0 1.8 C-2.2 3.2 -3 4.8 -2.8 6.8" stroke="#4a4038" stroke-width="1" fill="none" stroke-linecap="round"/>
    </g>
  </defs>
</svg>

<div class="grain pointer-events-none fixed inset-0 z-60 opacity-50 mix-blend-multiply" aria-hidden="true"></div>
<div class="wipe pointer-events-none fixed -inset-[6%_10%] z-55 translate-x-[-118%] -skew-x-8 bg-[linear-gradient(100deg,#1c1814,#241f1a_55%,#2c2620)]" id="wipe" aria-hidden="true"></div>
<svg class="pointer-events-none fixed inset-0 z-50" id="rippleLayer" aria-hidden="true"></svg>

<SiteHeader isHome />

<!-- ============ HOME ============ -->
<div class="view" data-route="home">
  <header class="relative min-h-svh overflow-hidden" id="hero">
    <svg class="pointer-events-none absolute top-0 left-0 z-0 h-auto w-full" viewBox="0 0 1200 620" preserveAspectRatio="xMidYMin slice" aria-hidden="true">
      <path class="hake" pathLength="1"
        d="M-70 330 C300 285 820 275 1270 315"
        stroke="#35302a" stroke-width="120" fill="none" stroke-linecap="round"
        filter="url(#hakeRough)"/>
    </svg>

    <svg class="pointer-events-none absolute top-[clamp(50px,7vh,84px)] left-0 z-1 h-auto w-full max-mobile:left-[-78%] max-mobile:w-[178%]" viewBox="0 0 1200 400" preserveAspectRatio="xMidYMin meet" aria-hidden="true">
      <g filter="url(#inkRough)">
        <!-- 幹（三段で先細り・左から横断） -->
        <path class="stk" pathLength="1" style="--dl:.1s"  stroke="#3b352d" stroke-width="13"  d="M-30 250 C80 238 150 258 260 246 C360 236 420 210 520 202"/>
        <path class="stk" pathLength="1" style="--dl:.55s" stroke="#43392f" stroke-width="8.5" d="M512 203 C610 196 660 206 750 196 C820 189 856 176 900 170"/>
        <path class="stk" pathLength="1" style="--dl:.95s" stroke="#4c4034" stroke-width="5"   d="M892 171 C960 160 990 138 1050 126 C1100 116 1140 120 1200 108"/>
        <path class="stk" pathLength="1" style="--dl:1.35s" stroke="#5d4f41" stroke-width="2.5" d="M1075 122 C1100 108 1112 92 1135 80"/>
        <!-- 上枝A -->
        <path class="stk" pathLength="1" style="--dl:.5s"  stroke="#453a30" stroke-width="6"   d="M300 246 C322 214 326 178 356 142"/>
        <path class="stk" pathLength="1" style="--dl:.85s" stroke="#52453a" stroke-width="3.5" d="M352 146 C372 118 398 100 434 88"/>
        <path class="stk" pathLength="1" style="--dl:1.15s" stroke="#5d4f41" stroke-width="2"  d="M380 112 C402 104 418 108 442 100"/>
        <path class="stk" pathLength="1" style="--dl:1.2s"  stroke="#5d4f41" stroke-width="2"  d="M356 140 C344 120 346 100 336 82"/>
        <!-- 下枝B -->
        <path class="stk" pathLength="1" style="--dl:.7s"  stroke="#453a30" stroke-width="5.5" d="M598 203 C622 232 630 266 664 292"/>
        <path class="stk" pathLength="1" style="--dl:1.05s" stroke="#52453a" stroke-width="3"  d="M660 289 C684 306 714 312 748 314"/>
        <path class="stk" pathLength="1" style="--dl:1.3s"  stroke="#5d4f41" stroke-width="2"  d="M676 298 C690 312 694 330 710 342"/>
        <path class="stk" pathLength="1" style="--dl:1.4s"  stroke="#5d4f41" stroke-width="1.8" d="M736 312 C748 296 762 290 780 284"/>
        <!-- 上枝C -->
        <path class="stk" pathLength="1" style="--dl:1s"   stroke="#453a30" stroke-width="5"   d="M828 181 C846 152 842 120 872 96"/>
        <path class="stk" pathLength="1" style="--dl:1.3s" stroke="#52453a" stroke-width="3"   d="M868 100 C890 82 916 76 946 72"/>
        <path class="stk" pathLength="1" style="--dl:1.55s" stroke="#5d4f41" stroke-width="2"  d="M884 88 C902 74 906 58 924 44"/>
        <path class="stk" pathLength="1" style="--dl:1.5s"  stroke="#5d4f41" stroke-width="1.8" d="M946 72 C972 64 992 68 1016 58"/>
        <!-- 小枝D -->
        <path class="stk" pathLength="1" style="--dl:.9s"  stroke="#52453a" stroke-width="3"   d="M428 222 C446 240 470 250 500 252"/>
        <!-- 追加：上枝E（左） -->
        <path class="stk" pathLength="1" style="--dl:.45s" stroke="#52453a" stroke-width="3"   d="M182 248 C192 215 184 185 200 152"/>
        <path class="stk" pathLength="1" style="--dl:.8s"  stroke="#5d4f41" stroke-width="1.8" d="M196 158 C212 140 228 138 248 128"/>
        <!-- 追加：上小枝G（中央） -->
        <path class="stk" pathLength="1" style="--dl:.95s" stroke="#5d4f41" stroke-width="2.2" d="M700 199 C712 172 706 148 722 122"/>
        <!-- 追加：下小枝H（左中） -->
        <path class="stk" pathLength="1" style="--dl:.75s" stroke="#5d4f41" stroke-width="2.2" d="M352 241 C364 263 382 273 408 277"/>
        <!-- 追加：下枝F（左） -->
        <path class="stk" pathLength="1" style="--dl:.6s"  stroke="#52453a" stroke-width="2.5" d="M260 246 C272 270 292 282 320 288"/>
        <!-- 追加：先端の上小枝 -->
        <path class="stk" pathLength="1" style="--dl:1.45s" stroke="#5d4f41" stroke-width="1.8" d="M1105 118 C1118 100 1116 82 1128 62"/>
        <!-- 苔点 -->
        <g class="mdot" fill="#3b352d">
          <ellipse cx="180" cy="245" rx="3.2" ry="2" transform="rotate(-12 180 245)"/>
          <ellipse cx="562" cy="199" rx="2.8" ry="1.8" transform="rotate(8 562 199)"/>
          <ellipse cx="762" cy="192" rx="2.6" ry="1.7" transform="rotate(-6 762 192)"/>
          <ellipse cx="1022" cy="130" rx="2.4" ry="1.6" transform="rotate(10 1022 130)"/>
          <ellipse cx="330" cy="230" rx="2.2" ry="1.5" transform="rotate(-20 330 230)"/>
        </g>
      </g>
      <g id="bloomLayer" filter="url(#inkRoughFine)"></g>
    </svg>

    <div class="petal-layer pointer-events-none absolute inset-0 z-3 overflow-hidden" aria-hidden="true"></div>

    <div class="absolute top-[clamp(300px,36vh,380px)] right-[6.5vw] z-4 flex flex-row-reverse gap-[2.4vmin] max-mobile:top-[30vh] max-mobile:right-[7vw]">
      <h1 class="hero-name m-0 text-[clamp(44px,7.8vmin,88px)] leading-[1.08] font-medium tracking-[.16em] [writing-mode:vertical-rl]">桜花爛漫</h1>
      <p class="hero-sub m-0 pt-[1.7em] text-[clamp(12px,1.9vmin,17px)] tracking-[.42em] text-ink-soft [writing-mode:vertical-rl]">静かに、手を動かす。</p>
    </div>

    <p class="hero-lead absolute bottom-[clamp(90px,16vh,160px)] left-[6.5vw] z-4 m-0 max-w-[44ch] text-[14.5px] leading-[2.3] tracking-[.14em] text-ink-soft max-mobile:bottom-[14vh] max-mobile:max-w-[64vw] max-mobile:text-[13px]">
      茨城高専 機械制御系。LLMエージェントのセキュリティを研究しながら、<br>
      墨のシミュレーションや、Webの小さな道具を作っています。
      <span class="mt-[1.2em] block font-latin text-[10.5px] font-medium tracking-[.36em] text-ink-faint">STUDENT · BUILDER — JUNA</span>
    </p>

    <a class="scroll-hint absolute bottom-6 left-1/2 z-4 flex -translate-x-1/2 flex-col items-center gap-2.5 text-[11px] tracking-[.5em] text-ink-soft no-underline [writing-mode:vertical-rl]" href="#about">巡る<span class="scroll-line h-11 w-px origin-top bg-linear-to-b from-ink-soft to-transparent"></span></a>
  </header>
  <main class="relative z-5">
    <section class="relative mx-auto min-h-[78svh] max-w-[1060px] px-[7vw] pt-[17vh] pb-[13vh] max-mobile:px-[8vw] max-mobile:pt-[14vh] max-mobile:pb-[10vh]" id="about">
      <span class="pointer-events-none absolute top-1/2 right-[2%] -translate-y-1/2 text-[min(32vmin,320px)] leading-none font-semibold text-ink opacity-5 select-none max-mobile:text-[42vmin]" aria-hidden="true">私</span>
      <div class="reveal">
        <p class="m-0 mb-[2em] flex items-center gap-3.5 font-latin text-xs font-semibold tracking-[.44em] text-vermilion before:h-px before:w-9 before:bg-current before:opacity-60">{about.eyebrow}</p>
        <h2 class="m-0 mb-[1.2em] text-[clamp(25px,3.4vmin,36px)] font-medium tracking-[.14em]">{about.title}</h2>
        {about.introduction.map((paragraph) => <p class="my-[1em] text-[15px] leading-[2.35] tracking-[.1em] text-[#4c453d]">{paragraph}</p>)}
      </div>

      <div class="reveal mt-[5em]">
        <h3 class="m-0 mb-[2.2em] flex items-center gap-3.5 text-[17px] font-semibold tracking-[.3em]">{about.footprint.title}<span class="font-latin text-[11px] font-medium tracking-[.4em] text-ink-faint">{about.footprint.subtitle}</span></h3>
        <ul class="relative m-0 list-none py-0 pr-0 pl-[26px] before:absolute before:top-1.5 before:bottom-1.5 before:left-0 before:w-0.5 before:rounded-sm before:bg-[linear-gradient(to_bottom,var(--color-ink)_0%,rgba(53,48,42,.35)_85%,transparent)] before:content-['']">
          {about.footprint.entries.map((entry) => (
            <li class="relative pb-[2.1em] pl-[22px] before:absolute before:top-[9px] before:left-[-26px] before:h-[9px] before:w-[9px] before:translate-x-[-3.5px] before:rotate-8 before:rounded-full before:bg-ink before:shadow-[1.5px_1px_0_rgba(53,48,42,.35)] before:content-[''] last:before:bg-vermilion">
              <span class="mb-[.35em] block font-latin text-[13px] font-semibold tracking-[.24em] text-vermilion">{entry.year}</span>
              <span class="text-[14.5px] leading-8 tracking-[.1em] text-[#4c453d]">{entry.text}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </main>
</div>

<!-- ============ WORKS ============ -->
<div class="view" data-route="works">
  <main class="relative z-5">
    <section class="relative mx-auto min-h-[78svh] max-w-[1060px] px-[7vw] pt-[17vh] pb-[13vh] max-mobile:px-[8vw] max-mobile:pt-[14vh] max-mobile:pb-[10vh]" id="works">
      <span class="pointer-events-none absolute top-1/2 left-[1%] -translate-y-1/2 text-[min(32vmin,320px)] leading-none font-semibold text-ink opacity-5 select-none max-mobile:text-[42vmin]" aria-hidden="true">作</span>
      <div class="reveal">
        <p class="m-0 mb-[2em] flex items-center gap-3.5 font-latin text-xs font-semibold tracking-[.44em] text-vermilion before:h-px before:w-9 before:bg-current before:opacity-60">{works.eyebrow}</p>
        <h2 class="m-0 mb-[1.2em] text-[clamp(25px,3.4vmin,36px)] font-medium tracking-[.14em]">{works.title}</h2>
        <div class="mt-[3em] grid grid-cols-[repeat(auto-fit,minmax(250px,1fr))] gap-[26px]">
          {works.items.map((item) => (
            <a class="group relative flex flex-col gap-[1em] rounded-sm border border-line bg-[rgba(255,252,242,.4)] px-[1.7em] pt-[2em] pb-[1.7em] text-inherit no-underline transition-[transform,border-color,box-shadow] duration-450 ease-in-out hover:-translate-y-[5px] hover:border-[rgba(177,58,42,.55)] hover:shadow-[0_14px_30px_-18px_rgba(53,48,42,.4)]" href={item.href}>
              <span class="flex h-11 w-11 -rotate-2 items-center justify-center rounded-[3px] border-[1.4px] border-ink text-[22px] font-semibold group-hover:border-vermilion group-hover:text-vermilion" aria-hidden="true">{item.character}</span>
              <h3 class="m-0 text-[17.5px] font-semibold tracking-[.12em]">{item.title}</h3>
              <p class="m-0 flex-1 text-[13px] leading-8 tracking-[.08em] text-ink-soft">{item.description}</p>
              <div class="flex flex-wrap gap-2">{item.tags.map((tag) => <span class="rounded-xs border border-line px-[.8em] py-[.35em] font-latin text-[10.5px] tracking-[.22em] text-ink-faint">{tag}</span>)}</div>
              <div class="flex gap-[1.6em] font-latin text-[11.5px] font-semibold tracking-[.26em] text-vermilion">{item.links.map((link) => <span>{link}</span>)}</div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</div>

<!-- ============ BLOG ============ -->
<div class="view" data-route="blog">
  <main class="relative z-5">
    <section class="relative mx-auto min-h-[78svh] max-w-[1060px] px-[7vw] pt-[17vh] pb-[13vh] max-mobile:px-[8vw] max-mobile:pt-[14vh] max-mobile:pb-[10vh]" id="blog">
      <span class="pointer-events-none absolute top-1/2 right-[2%] -translate-y-1/2 text-[min(32vmin,320px)] leading-none font-semibold text-ink opacity-5 select-none max-mobile:text-[42vmin]" aria-hidden="true">記</span>
      <div class="reveal">
        <p class="m-0 mb-[2em] flex items-center gap-3.5 font-latin text-xs font-semibold tracking-[.44em] text-vermilion before:h-px before:w-9 before:bg-current before:opacity-60">{blog.eyebrow}</p>
        <h2 class="m-0 mb-[1.2em] text-[clamp(25px,3.4vmin,36px)] font-medium tracking-[.14em]">{blog.title}</h2>
        <ul class="m-0 mt-[2.6em] list-none border-t border-line p-0">
          {posts.map((post) => (
            <li><a class="group flex items-center gap-[1.6em] border-b border-line px-[.4em] py-[1.5em] text-inherit no-underline transition-colors duration-350 hover:bg-[rgba(177,58,42,.05)]" href={`/blog/${post.id}/`}>
              <span class="min-w-[6.2em] font-latin text-xs tracking-[.2em] text-ink-faint max-mobile:min-w-[5.4em] max-mobile:text-[11px]">{formatBlogDate(post.data.pubDate)}</span>
              <span class="flex h-6 w-6 flex-none -rotate-2 items-center justify-center rounded-[3px] border-[1.3px] border-ink font-latin text-xs font-semibold group-hover:border-vermilion group-hover:text-vermilion" aria-hidden="true">{post.data.source}</span>
              <span class="text-[14.5px] leading-[1.9] tracking-[.08em]">{post.data.title}</span>
            </a></li>
          ))}
        </ul>
        <p class="mt-[2.2em] mb-[1em] text-[12.5px] tracking-[.14em] text-ink-faint">{blog.note}</p>
      </div>
    </section>
  </main>
</div>

<!-- ============ footer ============ -->
<footer class="flex flex-col items-center gap-[2.4em] border-t border-line px-[7vw] pt-[8vh] pb-[4em] text-center">
  <div class="flex flex-wrap justify-center gap-[2.4em]">
    <a class="group flex flex-col items-center gap-[.7em] text-ink no-underline" href="#" aria-label="GitHub"><span class="flex h-[46px] w-[46px] -rotate-2 items-center justify-center rounded-[3px] border-[1.6px] border-ink font-latin text-[17px] font-semibold transition-all duration-350 group-hover:rotate-1 group-hover:border-vermilion group-hover:bg-vermilion group-hover:text-paper">G</span><span class="font-latin text-[10px] tracking-[.3em] text-ink-faint">GITHUB</span></a>
    <a class="group flex flex-col items-center gap-[.7em] text-ink no-underline" href="#" aria-label="X"><span class="flex h-[46px] w-[46px] -rotate-2 items-center justify-center rounded-[3px] border-[1.6px] border-ink font-latin text-[17px] font-semibold transition-all duration-350 group-hover:rotate-1 group-hover:border-vermilion group-hover:bg-vermilion group-hover:text-paper">X</span><span class="font-latin text-[10px] tracking-[.3em] text-ink-faint">X</span></a>
    <a class="group flex flex-col items-center gap-[.7em] text-ink no-underline" href="#" aria-label="Zenn"><span class="flex h-[46px] w-[46px] -rotate-2 items-center justify-center rounded-[3px] border-[1.6px] border-ink font-latin text-[17px] font-semibold transition-all duration-350 group-hover:rotate-1 group-hover:border-vermilion group-hover:bg-vermilion group-hover:text-paper">Z</span><span class="font-latin text-[10px] tracking-[.3em] text-ink-faint">ZENN</span></a>
    <a class="group flex flex-col items-center gap-[.7em] text-ink no-underline" href="#" aria-label="Qiita"><span class="flex h-[46px] w-[46px] -rotate-2 items-center justify-center rounded-[3px] border-[1.6px] border-ink font-latin text-[17px] font-semibold transition-all duration-350 group-hover:rotate-1 group-hover:border-vermilion group-hover:bg-vermilion group-hover:text-paper">Q</span><span class="font-latin text-[10px] tracking-[.3em] text-ink-faint">QIITA</span></a>
  </div>
  <span class="font-latin text-[11px] tracking-[.3em] text-ink-faint">© 2026 Juna1013</span>
</footer>

<script src="../scripts/main.js"></script>
</body>
</html>
