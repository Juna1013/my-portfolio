---
import '../styles/global.css';
import HeroArtwork from '../components/HeroArtwork.astro';
import SeoHead from '../components/SeoHead.astro';
import SectionShell from '../components/SectionShell.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { about, acknowledgment, copyright, hero, seo, socialLinks } from '../data/about';
import { blog } from '../data/blog';
import { works } from '../data/works';
import { formatBlogDate, formatFootprintDate } from '../utils/date';
import { fetchLatestPosts } from '../utils/feeds';

const posts = await fetchLatestPosts();
---
<!DOCTYPE html>
<html lang="ja" id="top">
<head>
<SeoHead title={seo.title} description={seo.description} />
</head>
<body>

<div class="grain pointer-events-none fixed inset-0 z-60 opacity-50 mix-blend-multiply" aria-hidden="true"></div>
<div class="wipe pointer-events-none fixed -inset-[6%_10%] z-55 translate-x-[-118%] -skew-x-8 bg-[linear-gradient(100deg,#1c1814,#241f1a_55%,#2c2620)]" id="wipe" aria-hidden="true"></div>
<svg class="pointer-events-none fixed inset-0 z-50" id="rippleLayer" aria-hidden="true"></svg>

<SiteHeader isHome />

<!-- ============ HOME ============ -->
<div class="view" data-route="home">
  <header class="relative min-h-svh overflow-hidden" id="hero">
    <HeroArtwork />

    <div class="absolute top-[clamp(300px,36vh,380px)] right-[6.5vw] z-4 flex flex-row-reverse gap-[2.4vmin] max-mobile:top-[30vh] max-mobile:right-[7vw]">
      <h1 class="hero-name m-0 text-[clamp(44px,7.8vmin,88px)] leading-[1.08] font-medium tracking-[.16em] [writing-mode:vertical-rl]">{hero.name}</h1>
      <p class="hero-sub m-0 pt-[1.7em] text-[clamp(12px,1.9vmin,17px)] tracking-[.42em] text-ink-soft [writing-mode:vertical-rl]">{hero.sub}</p>
    </div>

    <p class="hero-lead absolute bottom-[clamp(90px,16vh,160px)] left-[6.5vw] z-4 m-0 max-w-[44ch] text-[14.5px] leading-[2.3] tracking-[.14em] text-ink-soft max-mobile:bottom-[17vh] max-mobile:max-w-[64vw] max-mobile:[@media(min-height:820px)]:max-w-[80vw] max-mobile:text-[13px]">
      {hero.leadLines.map((line, index) => (
        <>
          {index > 0 && <br />}
          {line}
        </>
      ))}
      <span class="mt-[1.2em] block font-latin text-[10.5px] font-medium tracking-[.36em] text-ink-faint">{hero.tagline}</span>
    </p>

    <a class="scroll-hint absolute bottom-6 left-1/2 z-4 flex -translate-x-1/2 flex-col items-center gap-2.5 text-[11px] tracking-[.5em] text-ink-soft no-underline [writing-mode:vertical-rl]" href="#about">{hero.scrollHint}<span class="scroll-line h-11 w-px origin-top bg-linear-to-b from-ink-soft to-transparent"></span></a>
  </header>
  <SectionShell id="about" ghost="私" eyebrow={about.eyebrow} title={about.title}>
    {about.introduction.map((paragraph) => <p class="my-[1em] text-[15px] leading-[2.35] tracking-[.1em] text-[#4c453d]">{paragraph}</p>)}

    <div class="mt-[3.2em]">
      {about.skills.map((group) => (
        <div class="mt-[2.2em] first:mt-0">
          <h3 class="m-0 mb-[1.2em] font-latin text-xs font-semibold tracking-[.32em] text-ink-soft">{group.title}</h3>
          <div class="flex flex-wrap gap-2">
            {group.items.map((item) => <span class="rounded-xs border border-line px-[.9em] py-[.45em] font-latin text-[11px] tracking-[.18em] text-ink-soft">{item}</span>)}
          </div>
        </div>
      ))}
    </div>

    <div slot="after" class="reveal mt-[5em]">
      <h3 class="m-0 mb-[2.2em] flex items-center gap-3.5 text-[17px] font-semibold tracking-[.3em]">{about.footprint.title}<span class="font-latin text-[11px] font-medium tracking-[.4em] text-ink-faint">{about.footprint.subtitle}</span></h3>
      <ul class="relative m-0 list-none py-0 pr-0 pl-[26px] before:absolute before:top-1.5 before:bottom-1.5 before:left-0 before:w-0.5 before:rounded-sm before:bg-[linear-gradient(to_bottom,var(--color-ink)_0%,rgba(53,48,42,.35)_85%,transparent)] before:content-['']">
        {about.footprint.entries.map((entry) => (
          <li class="relative pb-[2.1em] pl-[22px] before:absolute before:top-[9px] before:left-[-26px] before:h-[9px] before:w-[9px] before:translate-x-[-3.5px] before:rotate-8 before:rounded-full before:bg-ink before:shadow-[1.5px_1px_0_rgba(53,48,42,.35)] before:content-[''] last:before:bg-vermilion">
            <span class="mb-[.35em] block font-latin text-[13px] font-semibold tracking-[.24em] text-vermilion">{formatFootprintDate(entry.year)}</span>
            <span class="block text-[14.5px] leading-8 tracking-[.1em] text-[#4c453d]">{entry.text}</span>
            {entry.description && <span class="mt-[.25em] block text-[12.5px] leading-7 tracking-[.08em] text-ink-faint">{entry.description}</span>}
          </li>
        ))}
      </ul>
    </div>
  </SectionShell>
</div>

<!-- ============ WORKS ============ -->
<div class="view" data-route="works">
  <SectionShell id="works" ghost="作" ghostSide="left" eyebrow={works.eyebrow} title={works.title}>
    <div class="mt-[3em] grid grid-cols-[repeat(auto-fit,minmax(250px,1fr))] gap-[26px]">
      {works.items.map((item) => (
        <div class="group relative flex flex-col gap-[1em] rounded-sm border border-line bg-[rgba(255,252,242,.4)] px-[1.7em] pt-[2em] pb-[1.7em] transition-[transform,border-color,box-shadow] duration-450 ease-in-out hover:-translate-y-[5px] hover:border-[rgba(177,58,42,.55)] hover:shadow-[0_14px_30px_-18px_rgba(53,48,42,.4)]">
          <span class="flex h-11 w-11 -rotate-2 items-center justify-center rounded-[3px] border-[1.4px] border-ink text-[22px] font-semibold group-hover:border-vermilion group-hover:text-vermilion" aria-hidden="true">{item.character}</span>
          <h3 class="m-0 text-[17.5px] font-semibold tracking-[.12em]">{item.title}</h3>
          <p class="m-0 flex-1 text-[13px] leading-8 tracking-[.08em] text-ink-soft">{item.description}</p>
          <div class="flex flex-wrap gap-2">{item.tags.map((tag) => <span class="rounded-xs border border-line px-[.8em] py-[.35em] font-latin text-[10.5px] tracking-[.22em] text-ink-faint">{tag}</span>)}</div>
          <div class="flex gap-[1.6em] font-latin text-[11.5px] font-semibold tracking-[.26em] text-vermilion">
            {item.links.map((link) => <a class="no-underline underline-offset-4 hover:underline" href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a>)}
          </div>
        </div>
      ))}
    </div>
  </SectionShell>
</div>

<!-- ============ BLOG ============ -->
<div class="view" data-route="blog">
  <SectionShell id="blog" ghost="記" eyebrow={blog.eyebrow} title={blog.title}>
    <ul class="m-0 mt-[2.6em] list-none border-t border-line p-0">
      {posts.map((post) => (
        <li><a class="group flex items-center gap-[1.6em] border-b border-line px-[.4em] py-[1.5em] text-inherit no-underline transition-colors duration-350 hover:bg-[rgba(177,58,42,.05)]" href={post.url} target="_blank" rel="noopener noreferrer">
          <span class="min-w-[6.2em] font-latin text-xs tracking-[.2em] text-ink-faint max-mobile:min-w-[5.4em] max-mobile:text-[11px]">{formatBlogDate(post.pubDate)}</span>
          <span class="flex h-6 w-6 flex-none -rotate-2 items-center justify-center rounded-[3px] border-[1.3px] border-ink font-latin text-xs font-semibold group-hover:border-vermilion group-hover:text-vermilion" aria-hidden="true">{post.source}</span>
          <span class="text-[14.5px] leading-[1.9] tracking-[.08em]">{post.title}</span>
        </a></li>
      ))}
    </ul>
    <p class="mt-[2.2em] mb-[1em] text-[12.5px] tracking-[.14em] text-ink-faint">{blog.note}</p>
  </SectionShell>
</div>

<!-- ============ footer ============ -->
<footer class="flex flex-col items-center gap-[2.4em] border-t border-line px-[7vw] pt-[8vh] pb-[4em] text-center">
  <div class="flex flex-wrap justify-center gap-[2.4em]">
    {socialLinks.map((link) => (
      <a
        class="group flex flex-col items-center gap-[.7em] text-ink no-underline"
        href={link.href}
        aria-label={link.label}
        target={link.href.startsWith('http') ? '_blank' : undefined}
        rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
      >
        <span class="flex h-[46px] w-[46px] -rotate-2 items-center justify-center rounded-[3px] border-[1.6px] border-ink transition-all duration-350 group-hover:rotate-1 group-hover:border-vermilion group-hover:bg-vermilion group-hover:text-paper">
          <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24" aria-hidden="true"><path d={link.icon.path} /></svg>
        </span>
        <span class="font-latin text-[10px] tracking-[.3em] text-ink-faint">{link.text}</span>
      </a>
    ))}
  </div>
  <p class="m-0 text-[11.5px] leading-7 tracking-[.14em] text-ink-faint">
    {acknowledgment.prefix}<a class="text-ink-soft underline underline-offset-4 transition-colors duration-350 hover:text-vermilion" href={acknowledgment.href} target="_blank" rel="noopener noreferrer">{acknowledgment.linkText}</a>{acknowledgment.suffix}
  </p>
  <span class="font-latin text-[11px] tracking-[.3em] text-ink-faint">{copyright}</span>
</footer>

<script src="../scripts/main.js"></script>
</body>
</html>
