        <use href="#spetal" transform="rotate(0) translate(0 -7.4)" opacity=".95"/>
        <use href="#spetal" transform="rotate(72) translate(0 -7.4)" opacity=".85"/>
        <use href="#spetal" transform="rotate(144) translate(0 -7.4)" opacity=".9"/>
        <use href="#spetal" transform="rotate(216) translate(0 -7.4)" opacity=".82"/>
        <use href="#spetal" transform="rotate(288) translate(0 -7.4)" opacity=".88"/>
      </g>
      <circle r="1.7" fill="#a75f6f"/>
      <g fill="#e9d08a" opacity=".95">
        <circle cx="0" cy="-3" r=".6"/><circle cx="2.85" cy="-.95" r=".6"/>
        <circle cx="1.75" cy="2.45" r=".6"/><circle cx="-1.75" cy="2.45" r=".6"/>
        <circle cx="-2.85" cy="-.95" r=".6"/>
      </g>
    </g>
    <g id="sb1">
      <g fill="#cf8ea0" stroke="#a4677a" stroke-width=".5">
        <use href="#spetal" transform="rotate(0) translate(0 -7.4)" opacity=".93"/>
        <use href="#spetal" transform="rotate(72) translate(0 -7.4)" opacity=".84"/>
        <use href="#spetal" transform="rotate(144) translate(0 -7.4)" opacity=".9"/>
        <use href="#spetal" transform="rotate(216) translate(0 -7.4)" opacity=".8"/>
        <use href="#spetal" transform="rotate(288) translate(0 -7.4)" opacity=".87"/>
      </g>
      <circle r="1.7" fill="#8f4c5d"/>
    </g>
    <g id="sb2">
      <g fill="#f0e8d5" stroke="#4a4038" stroke-width=".8">
        <use href="#spetal" transform="rotate(0) translate(0 -7.4)"/>
        <use href="#spetal" transform="rotate(72) translate(0 -7.4)"/>
        <use href="#spetal" transform="rotate(144) translate(0 -7.4)"/>
        <use href="#spetal" transform="rotate(216) translate(0 -7.4)"/>
        <use href="#spetal" transform="rotate(288) translate(0 -7.4)"/>
      </g>
      <circle r="1.3" fill="#4a4038"/>
    </g>
    <g id="sbud">
      <circle r="2.8" fill="#d59aa9"/>
      <circle r="2.8" fill="none" stroke="#a4677a" stroke-width=".5"/>
      <path d="M0 1.8 C-2.2 3.2 -3 4.8 -2.8 6.8" stroke="#4a4038" stroke-width="1" fill="none" stroke-linecap="round"/>
    </g>
  </defs>
</svg>

<svg class="pointer-events-none absolute top-0 left-0 z-0 h-auto w-full" viewBox="0 0 1200 620" preserveAspectRatio="xMidYMin slice" aria-hidden="true">
