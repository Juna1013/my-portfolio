---
interface Props {
  isHome?: boolean;
  immediate?: boolean;
}

const { isHome = false, immediate = false } = Astro.props;
const links = isHome
  ? { home: '#/', works: '#/works', blog: '#/blog' }
  : { home: '/', works: '/#/works', blog: '/#/blog' };

const navItems = [
  { label: 'ABOUT', route: 'home' },
  { label: 'WORKS', route: 'works' },
  { label: 'BLOG', route: 'blog' },
] as const;
---

<nav class:list={[
  'site-nav fixed inset-x-0 top-0 z-40 flex items-center justify-between bg-[linear-gradient(to_bottom,rgba(240,232,213,.94)_55%,rgba(240,232,213,0))] px-[4.5vw] py-[18px]',
  { immediate },
]}>
  <a class="flex items-baseline gap-3 text-ink no-underline" href={links.home} data-route={isHome ? 'home' : undefined}>
    <span class="text-2xl leading-none font-semibold">栖</span><span class="font-latin text-[11.5px] tracking-[.42em] text-ink-faint">SUMIKA</span>
  </a>
  <ul class="m-0 flex list-none gap-[2.6em] p-0 max-mobile:gap-[1.6em]">
    {navItems.map((item) => (
      <li>
        <a
          class="nav-link border-b border-transparent pb-[3px] font-latin text-[13px] font-medium tracking-[.3em] text-ink-soft no-underline transition-colors duration-350 hover:text-vermilion"
          href={links[item.route]}
          data-route={isHome ? item.route : undefined}
        >{item.label}</a>
      </li>
    ))}
  </ul>
</nav>
