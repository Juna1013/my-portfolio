---
interface Props {
  isHome?: boolean;
  immediate?: boolean;
}

const { isHome = false, immediate = false } = Astro.props;
const links = isHome
  ? { home: '#/', works: '#/works', blog: '#/blog' }
  : { home: '/', works: '/#/works', blog: '/#/blog' };
---

<nav class={immediate ? 'immediate' : undefined}>
  <a class="logo" href={links.home} data-route={isHome ? 'home' : undefined}>
    <span class="kanji">栖</span><span class="latin">SUMIKA</span>
  </a>
  <ul class="nav-links">
    <li><a href={links.home} data-route={isHome ? 'home' : undefined}>ABOUT</a></li>
    <li><a href={links.works} data-route={isHome ? 'works' : undefined}>WORKS</a></li>
    <li><a href={links.blog} data-route={isHome ? 'blog' : undefined}>BLOG</a></li>
  </ul>
</nav>
